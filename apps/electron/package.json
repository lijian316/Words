{
  "name": "@typewords/electron",
  "version": "1.0.0",
  "private": true,
  "main": "main.mjs",
  "scripts": {
    "dev": "electron .",
    "build": "electron-builder --win",
    "build:dir": "electron-builder --win --dir"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^33.4.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "cc.typewords.app",
    "productName": "TypeWords",
    "copyright": "Copyright © 2024 TypeWords",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.mjs",
      "node_modules/**"
    ],
    "extraResources": [
      {
        "from": "../nuxt/.output/public",
        "to": "web"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "../nuxt/public/favicon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
